[brand]
name = "RSA Agentic"
version = "0.1.0"

[model]
provider = "deepseek"
model_name = "deepseek-v4-flash"
temperature = 0.3
max_tokens = 4096
ctx_size = 8192

[model.ollama]
host = "http://localhost:11434"

[model.openai]
api_key = ""
base_url = "https://api.openai.com/v1"
model = "gpt-4o"

[model.deepseek]
api_key = ""
base_url = "https://api.deepseek.com"
model = "deepseek-v4-flash"

[model.anthropic]
api_key = ""
model = "claude-sonnet-4-20250514"

[model.google]
api_key = ""
model = "gemini-2.0-flash"

[agent]
max_tool_iters = 15
system_prompt_file = "system.md"
need_approval = ["exec_shell","write_file","edit_file","sandbox_exec","any"]
verbose = false

[vectordb]
provider = "ollama"
model = "nomic-embed-text"
dimension = 768

[schedule]
enabled = false
interval_minutes = 60
